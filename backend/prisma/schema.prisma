generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

enum BillingType {
  PERCENTAGE
  FIXED
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String
  role       UserRole @default(VIEWER)
  employeeId Int?
  isActive   Boolean  @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Branch {
  id          Int      @id @default(autoincrement())
  branchName  String
  location    String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true)
  dispatcherPercent Float @default(25)
  accountsPercent   Float @default(10)

  employees   Employee[]
  companies   Company[]
  trucks      Truck[]
  drivers     Driver[]
  salarySlips SalarySlip[]
  invoices    Invoice[]
  loads       Load[]
  loadReports LoadReport[]
  loadReportReasons LoadReportReason[]
  partners           BranchPartner[]
  settlements        InvoiceSettlement[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BranchPartner {
  id        Int      @id @default(autoincrement())

  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  name      String
  percent   Float    @default(0)
  phone     String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvoiceSettlement {
  id                     Int      @id @default(autoincrement())

  branchId               Int
  branch                 Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  invoiceId              Int
  invoiceNumber          String?
  companyName            String?

  invoiceAmountUSD       Float    @default(0)
  usdRate                Float    @default(0)
  invoiceAmountPKR       Float    @default(0)

  dispatcherPercent      Float    @default(25)
  dispatcherAmountPKR    Float    @default(0)

  accountsPercent        Float    @default(10)
  accountsAmountPKR      Float    @default(0)

  partnerProfitPKR       Float    @default(0)

  partnerSplits          Json

  clearedBy              String?
  clearedAt              DateTime @default(now())

  notes                  String?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Employee {
  id          Int      @id @default(autoincrement())
  branchId    Int
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  name        String
  phone       String?
  email       String?
  cnic        String?
  role        String   @default("Staff")
  salaryType  String   @default("FIXED")
  fixedSalary Float    @default(0)
  commission  Float    @default(0)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Company {
  id               Int         @id @default(autoincrement())
  branchId         Int
  branch           Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)

  companyName      String
  ownerName        String?
  mcNumber         String?
  dotNumber        String?
  address          String?
  contactNumber    String?
  email            String?

  billingType      BillingType @default(PERCENTAGE)
  dispatchPercent  Float       @default(0)
  fixedMonthlyRate Float       @default(0)

  accountNumber    String?
  accountTitle     String?
  notes            String?

  trucks           Truck[]
  drivers          Driver[]

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Truck {
  id            Int      @id @default(autoincrement())
  branchId      Int
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  companyId     Int
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  truckNumber   String
  trailerNumber String?
  notes         String?

  drivers       Driver[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Driver {
  id        Int      @id @default(autoincrement())
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  companyId Int
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  truckId   Int?
  truck     Truck?   @relation(fields: [truckId], references: [id])

  name      String
  phone     String?
  email     String?
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SalarySlip {
  id                Int      @id @default(autoincrement())
  branchId          Int
  branch            Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  employeeId        Int
  employeeName      String
  designation       String?
  cnic              String?

  salaryType        String

  periodStart       DateTime
  periodEnd         DateTime

  dispatchCompany   String?
  dispatchAmountUSD Float    @default(0)
  commissionPercent Float    @default(0)
  employeeShareUSD  Float    @default(0)

  usdRate           Float    @default(0)
  fixedSalaryPKR    Float    @default(0)
  grossSalaryPKR    Float    @default(0)

  loanDeduction     Float    @default(0)
  advanceDeduction  Float    @default(0)
  otherDeduction    Float    @default(0)
  bonus             Float    @default(0)

  netSalaryPKR      Float    @default(0)
  notes             String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Invoice {
  id                          Int         @id @default(autoincrement())
  branchId                    Int
  branch                      Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)

  companyId                   Int?
  companyName                 String?
  ownerName                   String?
  mcNumber                    String?
  dotNumber                   String?
  address                     String?
  contactNumber               String?
  email                       String?

  billingType                 BillingType @default(PERCENTAGE)
  dispatchPercent             Float       @default(0)
  fixedMonthlyRate            Float       @default(0)

  truckNumbers                String?
  driverNames                 String?

  invoiceNumber               String?
  invoiceStart                DateTime
  invoiceEnd                  DateTime
  dueDate                     DateTime?

  accountNumber               String?
  accountTitle                String?

  accountsFeeWeeks            Float       @default(0)
  accountsFeeRate             Float       @default(0)
  accountsFeeTotal            Float       @default(0)

  totalLoadAmount             Float       @default(0)
  totalDispatchAmount         Float       @default(0)
  fixedBillingAmount          Float       @default(0)
  grossAmount                 Float       @default(0)

  discountAmount              Float       @default(0)
  referralBonus               Float       @default(0)
  fineAmount                  Float       @default(0)
  fineReason                  String?

  previousInvoiceAmount       Float       @default(0)
  includePreviousInvoiceInNet Boolean     @default(false)

  netPayable                  Float       @default(0)
  notes                       String?
  isCleared Boolean @default(false)
  clearedAt DateTime?

  loads                       InvoiceLoad[]

  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt
}

model InvoiceLoad {
  id              Int      @id @default(autoincrement())

  invoiceId       Int
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  date            DateTime
  pickup          String
  dropoff         String
  loadAmount      Float    @default(0)

  dispatchPercent Float    @default(0)
  dispatchAmount  Float    @default(0)
}

model Load {
  id              Int      @id @default(autoincrement())
  branchId        Int
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  companyId       Int?
  truckId         Int?
  driverId        Int?

  companyName     String?
  truckNumber     String?
  driverName      String?
  driverType      String?
  bookedByTeam    String?
  brokerNameCompany String?
  deliveryTime      String?
  pickupTime        String?
  loadNumber        String?

  loadDate        DateTime
  pickupDate      DateTime?
  dropoffDate     DateTime?

  pickup          String
  dropoff         String

  miles           Float    @default(0)
  ratePerMile     Float    @default(0)
  grossAmount     Float    @default(0)

  loadAmount      Float    @default(0)
  dispatchPercent Float    @default(0)
  dispatchAmount  Float    @default(0)

  source          String   @default("MANUAL")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LoadReportReason {
  id          Int      @id @default(autoincrement())
  branchId    Int
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  companyId   Int?
  truckId     Int?

  companyName String?
  truckNumber String?

  reasonDate  DateTime
  reasonType  String
  reasonNote  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LoadReport {
  id             Int      @id @default(autoincrement())
  branchId       Int
  branch         Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  companyId      Int?
  truckId        Int?

  companyName    String?
  ownerName      String?
  mcNumber       String?
  dotNumber      String?
  truckNumber    String?
  trailerNumber  String?

  reportTitle    String
  periodStart    DateTime
  periodEnd      DateTime

  totalLoads     Int      @default(0)
  totalMiles     Float    @default(0)
  totalGross     Float    @default(0)
  avgRatePerMile Float    @default(0)
  reasonDays     Int      @default(0)

  reportData     Json

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}